{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build C++ (PowerShell)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\build.ps1"
            ],
            "group": { "kind": "build", "isDefault": true },
            "presentation": { "reveal": "always", "panel": "shared" }
        },
        {
            "label": "Run C++ (PowerShell)",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\run.ps1"
            ],
            "group": "none",
            "presentation": { "reveal": "always", "panel": "shared" }
        }
    ]
}
